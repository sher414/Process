      <uipath:migrationVersion version="11.5" />
    </bpmn:extensionElements>
    <bpmn:startEvent id="Event_start" name="Update Software">
      <bpmn:extensionElements>
        <uipath:entryPointId value="fdd216a3-e6b9-439e-aa06-3a1473e5ee85" />
      </bpmn:extensionElements>
      <bpmn:outgoing>edge_Event_start-Activity_X3rvmM</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Activity_X3rvmM" name="Check Software Update">
      <bpmn:incoming>edge_Event_start-Activity_X3rvmM</bpmn:incoming>
      <bpmn:incoming>edge_FItBEB</bpmn:incoming>
      <bpmn:outgoing>edge_2J1ec5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_W5u3Bw" name="Is software Update available?">
      <bpmn:incoming>edge_2J1ec5</bpmn:incoming>
      <bpmn:outgoing>edge_Gateway_W5u3Bw-Activity_nUvtSX</bpmn:outgoing>
