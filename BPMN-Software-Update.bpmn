    </bpmn:task>
    <bpmn:task id="Activity_T7YJXQ" name="Instal Software">
      <bpmn:incoming>edge_Activity_nUvtSX-Activity_T7YJXQ</bpmn:incoming>
      <bpmn:outgoing>edge_Activity_T7YJXQ-Activity_U0EJSw</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_U0EJSw" name="Restart Laptop">
      <bpmn:incoming>edge_Activity_T7YJXQ-Activity_U0EJSw</bpmn:incoming>
      <bpmn:outgoing>edge_Activity_U0EJSw-Gateway_MX2elN</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_MX2elN" name="Is software updated?">
      <bpmn:incoming>edge_Activity_U0EJSw-Gateway_MX2elN</bpmn:incoming>
      <bpmn:outgoing>edge_UvrGRR</bpmn:outgoing>
      <bpmn:outgoing>edge_Gateway_MX2elN-Activity_UxNjfd</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_UxNjfd" name="Confirm Update">
      <bpmn:incoming>edge_Gateway_MX2elN-Activity_UxNjfd</bpmn:incoming>
      <bpmn:outgoing>edge_Activity_UxNjfd-Event_Eu3eyG</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_Eu3eyG" name="Software Updated">
      <bpmn:incoming>edge_Activity_UxNjfd-Event_Eu3eyG</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:intermediateThrowEvent id="Event_H5hrdv" name="Wait for IT instructions">
      <bpmn:incoming>edge_Activity_PhYqGb-Event_H5hrdv</bpmn:incoming>
      <bpmn:outgoing>edge_FItBEB</bpmn:outgoing>
    </bpmn:intermediateThrowEvent>
    <bpmn:sequenceFlow id="edge_Event_start-Activity_X3rvmM" sourceRef="Event_start" targetRef="Activity_X3rvmM" />
    <bpmn:sequenceFlow id="edge_2J1ec5" sourceRef="Activity_X3rvmM" targetRef="Gateway_W5u3Bw" />
