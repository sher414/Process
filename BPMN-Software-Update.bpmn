    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_nUvtSX" name="Download Software">
      <bpmn:incoming>edge_Gateway_W5u3Bw-Activity_nUvtSX</bpmn:incoming>
      <bpmn:outgoing>edge_Activity_nUvtSX-Activity_T7YJXQ</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_PhYqGb" name="Contact IT">
      <bpmn:incoming>edge_Gateway_W5u3Bw-Activity_PhYqGb</bpmn:incoming>
      <bpmn:incoming>edge_UvrGRR</bpmn:incoming>
